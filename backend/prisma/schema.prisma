// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             Int              @id @default(autoincrement())
  email          String           @unique
  username       String
  password       String
  isAdmin        Boolean          @default(false)
  profile        Profile?
  savedPlaces    UserSavedPlace[]
  reviews        Review[]
  trips          Trip[]
  documents      Document[]
  instagramSaves InstagramSave[]
}

model Profile {
  id                Int     @id @default(autoincrement())
  userId            Int     @unique
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio               String  @default("")
  location          String?
  currentlyVisiting String?
  profileImageUrl   String?
}

model Document {
  id              String       @id @default(cuid())
  userId          Int
  type            DocumentType
  title           String
  subtitle        String       @default("")
  date            DateTime
  endDate         DateTime?
  referenceNumber String?
  notes           String?
  imageUrl        String?      // R2 stored document image

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}

enum DocumentType {
  PASSPORT
  VISA
  FLIGHT
  HOTEL
  INSURANCE
  TRAVEL_DOC
  TRANSPORT
  BUS
  OTHER
}

model InstagramSave {
  id            String   @id @default(cuid())
  userId        Int
  instagramUrl  String
  placeName     String
  address       String?
  notes         String?
  sourceHandle  String?  // @username extracted from share text

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Place {
  id      String @id @default(cuid())
  placeId String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cache GooglePlaceCache?

  saves   UserSavedPlace[]
  reviews Review[]

  @@index([placeId])
}

model GooglePlaceCache {
  id String @id @default(cuid())

  // Temporary coordinates cache only.
  // Per current policy direction, keep placeId permanently in Place,
  // and refresh/delete lat/lng based on fetchedAt within 30 days.
  placeId String @unique
  lat     Float
  lng     Float

  fetchedAt DateTime @default(now())

  place Place @relation(fields: [placeId], references: [placeId], onDelete: Cascade)

  @@index([fetchedAt])
}

model Trip {
  id           String   @id @default(cuid())
  userId       Int
  name         String   @default("My Trip")
  city         String?
  Country      String?
  countryCode  String?  // ISO 3166-1 alpha-2 (e.g. "TH", "FR")
  startDate    DateTime?
  endDate      DateTime?
  hasItinerary Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedPlaces UserSavedPlace[]

  @@index([userId])
}

model UserSavedPlace {
  id String @id @default(cuid())

  userId    Int
  placeId   String
  tripId    String
  status    Status        @default(WISHLIST)
  category  PlaceCategory @default(OTHER)
  userNotes String?
  dayNumber Int?      // For itinerary: which day this place is assigned to
  visitedAt DateTime? // Timestamp when status changed to VISITED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [placeId], onDelete: Cascade)
  trip  Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([userId, placeId, tripId])
  @@index([userId])
  @@index([placeId])
  @@index([tripId])
  @@index([status])
  @@index([visitedAt])
}

model Review {
  id String @id @default(cuid())

  userId  Int
  placeId String

  rating  Int // 1-5 stars
  comment String // Review text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [placeId], onDelete: Cascade)

  @@unique([userId, placeId]) // One review per user per place
  @@index([userId])
  @@index([placeId])
  @@index([rating]) // For filtering by rating
}

enum Status {
  WISHLIST
  VISITED
  SKIPPED
}

enum PlaceCategory {
  FOOD_DRINK
  STAY
  SIGHTSEEING
  NATURE
  SHOPPING
  NIGHTLIFE
  WELLNESS
  OTHER
}
